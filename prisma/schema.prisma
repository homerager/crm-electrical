generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STOREKEEPER
}

enum ObjectStatus {
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum InvoiceType {
  INCOMING
  OUTGOING
}

enum MovementType {
  WAREHOUSE_TO_WAREHOUSE
  WAREHOUSE_TO_OBJECT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           Role     @default(STOREKEEPER)
  isActive       Boolean  @default(true)
  phone          String?
  telegramChatId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoices      Invoice[]
  movements     Movement[]
  createdTasks  Task[]     @relation("TaskCreatedBy")
  assignedTasks Task[]     @relation("TaskAssignedTo")
  timeLogs      TimeLog[]
  comments      TaskComment[]
  attachments   TaskAttachment[]

  @@map("users")
}

model Warehouse {
  id          String   @id @default(cuid())
  name        String
  address     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock         WarehouseStock[]
  invoices      Invoice[]
  movementsFrom Movement[]       @relation("MovementFrom")
  movementsTo   Movement[]       @relation("MovementTo")

  @@map("warehouses")
}

model ConstructionObject {
  id          String       @id @default(cuid())
  name        String
  address     String?
  description String?
  status      ObjectStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  movements Movement[]
  tasks     Task[]

  @@map("construction_objects")
}

model Contractor {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices Invoice[]

  @@map("contractors")
}

model ProductGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("product_groups")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?  @unique
  unit        String   @default("шт")
  groupId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group         ProductGroup?    @relation(fields: [groupId], references: [id])
  stock         WarehouseStock[]
  invoiceItems  InvoiceItem[]
  movementItems MovementItem[]

  @@map("products")
}

model WarehouseStock {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("warehouse_stock")
}

model Invoice {
  id           String      @id @default(cuid())
  number       String
  type         InvoiceType
  contractorId String?
  warehouseId  String
  createdById  String
  date         DateTime
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  contractor Contractor? @relation(fields: [contractorId], references: [id])
  warehouse  Warehouse   @relation(fields: [warehouseId], references: [id])
  createdBy  User        @relation(fields: [createdById], references: [id])
  items      InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id           String  @id @default(cuid())
  invoiceId    String
  productId    String
  quantity     Decimal @db.Decimal(12, 3)
  pricePerUnit Decimal @default(0) @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Movement {
  id              String       @id @default(cuid())
  type            MovementType
  fromWarehouseId String
  toWarehouseId   String?
  objectId        String?
  createdById     String
  date            DateTime
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  fromWarehouse Warehouse           @relation("MovementFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse?          @relation("MovementTo", fields: [toWarehouseId], references: [id])
  object        ConstructionObject? @relation(fields: [objectId], references: [id])
  createdBy     User                @relation(fields: [createdById], references: [id])
  items         MovementItem[]

  @@map("movements")
}

model MovementItem {
  id         String  @id @default(cuid())
  movementId String
  productId  String
  quantity   Decimal @db.Decimal(12, 3)

  movement Movement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("movement_items")
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  assignedToId   String?
  createdById    String
  objectId       String?
  parentId       String?
  dueDate        DateTime?
  estimatedHours Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  object    ConstructionObject? @relation(fields: [objectId], references: [id])
  createdBy User                @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignee  User?               @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  parent    Task?               @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks  Task[]              @relation("SubTasks")
  timeLogs    TimeLog[]
  comments    TaskComment[]
  attachments TaskAttachment[]

  @@map("tasks")
}

model TimeLog {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  hours       Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("time_logs")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  filename  String
  storedAs  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("task_attachments")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STOREKEEPER
  USER
  EMPLOYEE
}

enum ObjectStatus {
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum InvoiceType {
  INCOMING
  OUTGOING
}

enum MovementType {
  WAREHOUSE_TO_WAREHOUSE
  WAREHOUSE_TO_OBJECT
  /// Списання залишку на обʼєкті (використано)
  OBJECT_WRITE_OFF
  /// Повернення залишку з обʼєкта на склад
  OBJECT_TO_WAREHOUSE
}

enum ProjectMemberRole {
  OWNER
  MEMBER
}

enum PurchaseRequestStatus {
  DRAFT
  APPROVED
  ORDERED
  RECEIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model JobTitle {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("job_titles")
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  passwordHash   String
  role           Role      @default(STOREKEEPER)
  isActive       Boolean   @default(true)
  phone          String?
  telegramChatId     String?
  emailNotifications Boolean   @default(true)
  jobTitleId         String?
  jobTitle       JobTitle? @relation(fields: [jobTitleId], references: [id], onDelete: SetNull)
  /// Погодинна ставка (грн/год) для зарплатного звіту
  hourlyRate     Decimal?  @db.Decimal(12, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invoices      Invoice[]
  movements     Movement[]
  createdTasks  Task[]     @relation("TaskCreatedBy")
  assignedTasks Task[]     @relation("TaskAssignedTo")
  timeLogs          TimeLog[] @relation("TimeLogWork")
  timeLogsCreated   TimeLog[] @relation("TimeLogCreatedBy")
  comments        TaskComment[]
  attachments     TaskAttachment[]
  projectsCreated Project[]
  projectMembers  ProjectMember[]
  notifications   Notification[]
  purchaseRequests PurchaseRequest[]
  proposals       Proposal[]

  @@map("users")
}

model Warehouse {
  id          String   @id @default(cuid())
  name        String
  address     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock                      WarehouseStock[]
  objectStockReservations    WarehouseObjectReservation[]
  invoices                   Invoice[]
  movementsFrom              Movement[]       @relation("MovementFrom")
  movementsTo                Movement[]       @relation("MovementTo")

  @@map("warehouses")
}

model ConstructionObject {
  id          String       @id @default(cuid())
  name        String
  address     String?
  description String?
  status      ObjectStatus @default(ACTIVE)
  /// Загальний бюджет обʼєкта (грн)
  budget        Decimal?     @db.Decimal(14, 2)
  /// Відсоток націнки для кошторису та акту виконаних робіт
  markupPercent Decimal?     @db.Decimal(5, 2)
  /// Відсоток ПДВ у документах для клієнта (0 = без ПДВ, 20 = ПДВ 20%). Якщо null — береться defaultClientVatPercent з Settings
  clientVatPercent Decimal? @db.Decimal(5, 2)
  clientId      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client                    Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  movements                 Movement[]
  stock                     ObjectStock[]
  warehouseStockReservations WarehouseObjectReservation[]
  purchaseRequests           PurchaseRequest[]
  tasks                     Task[]
  timeLogs                  TimeLog[]
  /// Проєкти, де цей обʼєкт обраний як типовий для нових завдань
  projectsWithDefaultObject Project[]

  @@map("construction_objects")
}

model Client {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  /// ЄДРПОУ (юрособа) або ІПН (ФОП)
  taxCode       String?
  iban          String?
  bankName      String?
  bankMfo       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  objects ConstructionObject[]

  @@map("clients")
}

model Contractor {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  /// ЄДРПОУ (юрособа) або ІПН (ФОП)
  taxCode       String?
  iban          String?
  bankName      String?
  bankMfo       String?
  paymentNotes  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices Invoice[]
  purchaseRequests PurchaseRequest[]

  @@map("contractors")
}

model ProductGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("product_groups")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?  @unique
  unit        String   @default("шт")
  groupId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group         ProductGroup?    @relation(fields: [groupId], references: [id])
  stock         WarehouseStock[]
  warehouseObjectReservations WarehouseObjectReservation[]
  invoiceItems   InvoiceItem[]
  movementItems  MovementItem[]
  objectStock    ObjectStock[]
  purchaseRequestItems PurchaseRequestItem[]

  @@map("products")
}

model WarehouseStock {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("warehouse_stock")
}

/// Резерв товару на складі під конкретний будівельний обʼєкт (фізично залишається на складі)
model WarehouseObjectReservation {
  id          String   @id @default(cuid())
  objectId    String
  warehouseId String
  productId   String
  quantity    Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt   DateTime @updatedAt

  object    ConstructionObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  warehouse Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product            @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([objectId, warehouseId, productId])
  @@map("warehouse_object_reservations")
}

/// Залишок матеріалів на будівельному обʼєкті (після відпуску зі складу; зменшується при списанні та поверненні)
model ObjectStock {
  id        String   @id @default(cuid())
  objectId  String
  productId String
  quantity  Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt DateTime @updatedAt

  object   ConstructionObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  product  Product            @relation(fields: [productId], references: [id])

  @@unique([objectId, productId])
  @@map("object_stock")
}

model Invoice {
  id           String      @id @default(cuid())
  number       String
  type         InvoiceType
  contractorId String?
  warehouseId  String
  createdById  String
  date         DateTime
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  contractor Contractor? @relation(fields: [contractorId], references: [id])
  warehouse  Warehouse   @relation(fields: [warehouseId], references: [id])
  createdBy  User        @relation(fields: [createdById], references: [id])
  items      InvoiceItem[]
  purchaseRequests PurchaseRequest[]

  @@map("invoices")
}

model InvoiceItem {
  id           String  @id @default(cuid())
  invoiceId    String
  productId    String
  quantity     Decimal @db.Decimal(12, 3)
  pricePerUnit Decimal @default(0) @db.Decimal(12, 2)
  /// Відсоток ПДВ для цієї позиції (0 = без ПДВ, 20 = ПДВ 20%)
  vatPercent   Decimal @default(0) @db.Decimal(5, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Movement {
  id              String       @id @default(cuid())
  type            MovementType
  /// Для списання та повернення з обʼєкта може бути порожнім
  fromWarehouseId String?
  toWarehouseId   String?
  objectId        String?
  createdById     String
  date            DateTime
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  fromWarehouse Warehouse?          @relation("MovementFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse?          @relation("MovementTo", fields: [toWarehouseId], references: [id])
  object        ConstructionObject? @relation(fields: [objectId], references: [id])
  createdBy     User                @relation(fields: [createdById], references: [id])
  items         MovementItem[]

  @@map("movements")
}

model MovementItem {
  id         String  @id @default(cuid())
  movementId String
  productId  String
  quantity   Decimal @db.Decimal(12, 3)

  movement Movement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("movement_items")
}

model PurchaseRequest {
  id          String                @id @default(cuid())
  objectId    String
  contractorId String?
  status      PurchaseRequestStatus @default(DRAFT)
  createdById String
  invoiceId   String?
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  object    ConstructionObject @relation(fields: [objectId], references: [id], onDelete: Cascade)
  contractor Contractor?        @relation(fields: [contractorId], references: [id], onDelete: SetNull)
  createdBy User               @relation(fields: [createdById], references: [id])
  invoice   Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  items     PurchaseRequestItem[]

  @@index([objectId, status])
  @@index([contractorId])
  @@index([createdById])
  @@index([invoiceId])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                     String  @id @default(cuid())
  purchaseRequestId      String
  productId              String
  quantity               Decimal @db.Decimal(12, 3)
  estimatedPricePerUnit  Decimal @default(0) @db.Decimal(12, 2)
  /// Відсоток ПДВ для цієї позиції (0 = без ПДВ, 20 = ПДВ 20%)
  vatPercent             Decimal @default(0) @db.Decimal(5, 2)
  note                   String?

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("purchase_request_items")
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  assignedToId   String?
  createdById    String
  objectId       String?
  projectId      String?
  parentId       String?
  dueDate        DateTime?
  estimatedHours Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  object    ConstructionObject? @relation(fields: [objectId], references: [id])
  createdBy User                @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignee  User?               @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  project   Project?            @relation(fields: [projectId], references: [id])
  parent    Task?               @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks  Task[]              @relation("SubTasks")
  timeLogs    TimeLog[]
  comments    TaskComment[]
  attachments TaskAttachment[]

  @@map("tasks")
}

model TimeLog {
  id          String   @id @default(cuid())
  taskId      String?
  objectId    String?
  userId      String
  /// Хто створив запис (на кого години — userId)
  createdById String?
  hours       Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  task      Task?               @relation(fields: [taskId], references: [id], onDelete: SetNull)
  object    ConstructionObject? @relation(fields: [objectId], references: [id], onDelete: SetNull)
  user      User                @relation("TimeLogWork", fields: [userId], references: [id])
  createdBy User?               @relation("TimeLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@map("time_logs")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
  parent   TaskComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Restrict)
  replies  TaskComment[] @relation("CommentReplies")
  attachments TaskAttachment[]

  @@index([parentId])
  @@map("task_comments")
}

model Project {
  id               String   @id @default(cuid())
  name             String
  description      String?
  color            String   @default("#1976D2")
  createdById      String
  /// Типовий будівельний обʼєкт для нових завдань у цьому проєкті
  defaultObjectId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy     User                 @relation(fields: [createdById], references: [id])
  defaultObject ConstructionObject? @relation(fields: [defaultObjectId], references: [id], onDelete: SetNull)
  members       ProjectMember[]
  tasks         Task[]

  @@map("projects")
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  commentId String?
  filename  String
  storedAs  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  task    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  comment TaskComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("task_attachments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

/// Глобальні налаштування CRM (singleton, id = "global")
model Settings {
  id                           String   @id @default("global")
  /// Загальна націнка на матеріали (%), якщо на обʼєкті не задана окрема
  defaultMaterialMarkupPercent Decimal? @db.Decimal(5, 2)
  /// Загальна націнка на роботи працівників (%), якщо на обʼєкті не задана окрема
  defaultLaborMarkupPercent    Decimal? @db.Decimal(5, 2)
  /// Типовий % ПДВ для закупівлі товарів (накладні, заявки). Наприклад 20
  defaultVatPercent            Decimal? @db.Decimal(5, 2)
  /// Типовий % ПДВ у документах для клієнта (кошторис, акт, договір). Наприклад 20
  defaultClientVatPercent      Decimal? @db.Decimal(5, 2)
  updatedAt                    DateTime @updatedAt

  @@map("settings")
}

/// Набір банківських реквізитів виконавця для документів
model Requisite {
  id          String   @id @default(cuid())
  /// Назва набору (напр. "ФОП Іванов І.І.", "ТОВ Компанія")
  name        String
  companyName String?
  taxCode     String?
  iban        String?
  bankName    String?
  bankMfo     String?
  address     String?
  phone       String?
  email       String?
  /// Чи є цей набір реквізитів типовим (використовується в документах за замовчуванням)
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proposals Proposal[]

  @@map("requisites")
}

/// Незалежний каталог товарів/послуг для комерційних пропозицій (не повʼязаний з основними товарами)
model ProposalProduct {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?
  unit        String   @default("шт")
  groupName   String?
  priceExVat  Decimal  @default(0) @db.Decimal(14, 2)
  vatPercent  Decimal  @default(20) @db.Decimal(5, 2)
  notes       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proposalItems ProposalItem[]

  @@map("proposal_products")
}

model Proposal {
  id               String    @id @default(cuid())
  title            String
  subtitle         String?
  tagline          String?
  date             DateTime  @default(now())
  usdRate          Decimal?  @db.Decimal(8, 4)
  requisiteId      String?
  worksDescription String?
  techSpecs        String?
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  requisite Requisite? @relation(fields: [requisiteId], references: [id], onDelete: SetNull)
  createdBy User       @relation(fields: [createdById], references: [id])
  items     ProposalItem[]

  @@index([createdById])
  @@map("proposals")
}

model ProposalItem {
  id                String  @id @default(cuid())
  proposalId        String
  proposalProductId String?
  name              String
  quantity          Decimal @default(1) @db.Decimal(12, 3)
  unit              String  @default("шт")
  priceExVat        Decimal @default(0) @db.Decimal(14, 2)
  vatPercent        Decimal @default(0) @db.Decimal(5, 2)
  highlight         String?
  spec              String?
  sortOrder         Int     @default(0)

  proposal        Proposal         @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  proposalProduct ProposalProduct? @relation(fields: [proposalProductId], references: [id], onDelete: SetNull)

  @@index([proposalId])
  @@map("proposal_items")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String?
  action     String
  entityType String
  entityId   String
  changes    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
